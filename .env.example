# optimus configuration. Copy to .env and fill in. NEVER commit real secrets.

# Tenancy: single (self-hosted) or multi (SaaS)
OPTIMUS_TENANCY=single

# Discord
OPTIMUS_DISCORD_TOKEN=
OPTIMUS_DISCORD_CLIENT_ID=
OPTIMUS_DISCORD_CLIENT_SECRET=

# Gateway sharding (optional; see docs/sharding.md)
# Leave both unset for hikari automatic single-shard behaviour. Discord requires
# sharding past ~2,500 guilds. SHARD_COUNT is the fleet-wide total (all replicas
# must agree); SHARD_IDS picks which shards THIS replica runs as a spec string of
# comma-separated ids and inclusive ranges, e.g. "0-1" or "0,2,4". Omitting
# SHARD_IDS runs all shards in one process.
OPTIMUS_SHARD_COUNT=
OPTIMUS_SHARD_IDS=

# Datastores
# For docker compose these are overridden to the in-cluster hostnames
# (postgres/redis/nats); the values below target a local non-Docker setup.
OPTIMUS_DATABASE_URL=postgresql+asyncpg://optimus:optimus@localhost:5432/optimus
OPTIMUS_REDIS_URL=redis://localhost:6379/0
OPTIMUS_NATS_URL=nats://localhost:4222

# Postgres credentials for the docker compose stack. Compose builds
# OPTIMUS_DATABASE_URL from these, so change all three together. Use a strong
# password for any non-local deployment.
POSTGRES_USER=optimus
POSTGRES_PASSWORD=optimus
POSTGRES_DB=optimus

# Logging / observability
OPTIMUS_LOG_LEVEL=INFO
OPTIMUS_SERVICE_NAME=optimus
OPTIMUS_OTEL_ENABLED=false
OPTIMUS_OTEL_ENDPOINT=

# Health server
OPTIMUS_HEALTH_HOST=0.0.0.0
OPTIMUS_HEALTH_PORT=8080

# Ingest (SSRF-hardened fetcher)
OPTIMUS_INGEST_MAX_BYTES=10485760
OPTIMUS_INGEST_MAX_REDIRECTS=3

# Detection
OPTIMUS_DECODE_TIMEOUT_SECONDS=5
OPTIMUS_DECODE_CPU_SECONDS=5
OPTIMUS_DECODE_MEM_BYTES=536870912
OPTIMUS_MAX_IMAGE_PIXELS=24000000
OPTIMUS_MAX_FRAMES=8
OPTIMUS_SENSITIVITY_DEFAULT=balanced
OPTIMUS_EMBEDDING_ENABLED=false
OPTIMUS_EMBEDDING_MODEL_PATH=

# Rate limiting
# Backend: "memory" (default, per-process — correct for a single replica) or
# "redis" (shared bucket across replicas so effective limits don't multiply).
OPTIMUS_RATELIMIT_BACKEND=memory
OPTIMUS_RATELIMIT_REDIS_PREFIX=optimus:rl

# Evidence storage (optional S3/MinIO)
OPTIMUS_EVIDENCE_ENABLED=false
OPTIMUS_EVIDENCE_TTL_SECONDS=3600

# Global hash DB signing (Ed25519, base64). Generate per deployment.
OPTIMUS_GLOBAL_SIGNING_PUBLIC_KEY=
OPTIMUS_GLOBAL_SIGNING_PRIVATE_KEY=
