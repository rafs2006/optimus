# Optimus configuration. Copy to .env and fill in. NEVER commit real secrets.
#
# ── Simple mode (the default) ─────────────────────────────────────────────────
# Running the bot needs exactly ONE setting: your Discord bot token. Everything
# below this block is advanced/distributed-mode tuning you can ignore to start.

# Your Discord bot token (https://discord.com/developers/applications -> your
# app -> Bot -> Reset Token). This is the only required setting in simple mode.
OPTIMUS_DISCORD_TOKEN=

# Where simple mode stores its SQLite database. The default writes optimus.db in
# the working directory; point it at a path you own if that is not writable.
OPTIMUS_SIMPLE_DATABASE_URL=sqlite+aiosqlite:///optimus.db

# Log verbosity: INFO (default) is quiet and readable; DEBUG includes the full
# hikari gateway/REST firehose.
OPTIMUS_LOG_LEVEL=INFO

# ══════════════════════════════════════════════════════════════════════════════
# ADVANCED — distributed mode (OPTIMUS_MODE=distributed) and tuning.
# You do NOT need anything below to run the bot in simple mode.
# ══════════════════════════════════════════════════════════════════════════════

# Process mode: simple (default, one process, zero external services) or
# distributed (six services over NATS/Redis/Postgres). See docs/architecture.md.
OPTIMUS_MODE=simple

# Tenancy: single (self-hosted) or multi (SaaS, row-level-security multi-tenant).
OPTIMUS_TENANCY=single

# Discord application identifiers (distributed mode / manual command registration
# via scripts/register_commands.py; simple mode auto-registers and needs neither).
OPTIMUS_DISCORD_CLIENT_ID=
OPTIMUS_DISCORD_CLIENT_SECRET=

# Gateway sharding (optional; see docs/sharding.md)
# Leave both unset for hikari automatic single-shard behaviour. Discord requires
# sharding past ~2,500 guilds. SHARD_COUNT is the fleet-wide total (all replicas
# must agree); SHARD_IDS picks which shards THIS replica runs as a spec string of
# comma-separated ids and inclusive ranges, e.g. "0-1" or "0,2,4". Omitting
# SHARD_IDS runs all shards in one process.
OPTIMUS_SHARD_COUNT=
OPTIMUS_SHARD_IDS=

# Datastores (distributed mode only). For docker compose these are overridden to
# the in-cluster hostnames (postgres/redis/nats); the values below target a local
# non-Docker setup.
OPTIMUS_DATABASE_URL=postgresql+asyncpg://optimus:optimus@localhost:5432/optimus
OPTIMUS_REDIS_URL=redis://localhost:6379/0
OPTIMUS_NATS_URL=nats://localhost:4222

# Database connection pool (per replica). Effective DB-side cap is
# replicas * (POOL_SIZE + MAX_OVERFLOW) against one Postgres max_connections;
# front the DB with pgbouncer (transaction mode) at large fleets. See
# docs/scaling.md for the asyncpg + prepared-statement caveat.
OPTIMUS_DB_POOL_SIZE=5
OPTIMUS_DB_MAX_OVERFLOW=10
OPTIMUS_DB_POOL_RECYCLE=1800
OPTIMUS_DB_POOL_PRE_PING=true

# Data retention (deployment-wide batched purge). Unset/empty keeps everything
# (the default), so self-hosters lose no data. Set a positive day count to
# enable purging detections/appeals older than that many days.
OPTIMUS_DETECTION_RETENTION_DAYS=
OPTIMUS_RETENTION_BATCH_SIZE=1000
OPTIMUS_RETENTION_BATCH_PAUSE_SECONDS=0.5

# Postgres credentials for the docker compose stack. Compose builds
# OPTIMUS_DATABASE_URL from these, so change all three together. Use a strong
# password for any non-local deployment.
POSTGRES_USER=optimus
POSTGRES_PASSWORD=optimus
POSTGRES_DB=optimus

# Logging / observability
OPTIMUS_SERVICE_NAME=optimus
OPTIMUS_OTEL_ENABLED=false
OPTIMUS_OTEL_ENDPOINT=

# Health server
OPTIMUS_HEALTH_HOST=0.0.0.0
OPTIMUS_HEALTH_PORT=8080

# Ingest (SSRF-hardened fetcher)
OPTIMUS_INGEST_MAX_BYTES=10485760
# Hard cap on bytes shipped inline (base64) through NATS; must be <= MAX_BYTES.
# Oversized fetches are dropped (acked + metric), not published.
#
# IMPORTANT: images ride inline as base64, so a raw image of this many bytes
# inflates ~4/3 (plus a small JSON/header envelope) on the NATS wire. The NATS
# server's max_payload must exceed that wire size or the publish fails and the
# image is never scanned. The bundled docker-compose.yml sets NATS
# --max_payload=12582912 (12 MiB) to cover the 8 MiB default here; if you run
# your own NATS, raise its max_payload to at least ~ceil(INLINE * 4/3) + 4 KiB.
# The ingest service validates this at startup and refuses to run on a mismatch.
OPTIMUS_INGEST_MAX_INLINE_BYTES=8388608
OPTIMUS_INGEST_MAX_REDIRECTS=3
# Max inspectable images processed per Discord message (raid fan-out guard).
OPTIMUS_GATEWAY_MAX_ATTACHMENTS=10

# Detection
OPTIMUS_DECODE_TIMEOUT_SECONDS=5
OPTIMUS_DECODE_CPU_SECONDS=5
OPTIMUS_DECODE_MEM_BYTES=536870912
OPTIMUS_MAX_IMAGE_PIXELS=24000000
OPTIMUS_MAX_FRAMES=8
OPTIMUS_SENSITIVITY_DEFAULT=balanced
OPTIMUS_EMBEDDING_ENABLED=false
OPTIMUS_EMBEDDING_MODEL_PATH=

# Rate limiting
# Backend: "memory" (default, per-process — correct for a single replica) or
# "redis" (shared bucket across replicas so effective limits don't multiply).
OPTIMUS_RATELIMIT_BACKEND=memory
OPTIMUS_RATELIMIT_REDIS_PREFIX=optimus:rl

# Evidence storage (optional S3/MinIO)
OPTIMUS_EVIDENCE_ENABLED=false
OPTIMUS_EVIDENCE_TTL_SECONDS=3600

# Global hash DB signing (Ed25519, base64). Generate per deployment.
OPTIMUS_GLOBAL_SIGNING_PUBLIC_KEY=
OPTIMUS_GLOBAL_SIGNING_PRIVATE_KEY=
